# ─── Hosts (DNS A records doivent pointer vers le serveur) ──────────────────
API_HOST=api.vizhome.fr
MINIO_PUBLIC_HOST=cdn.vizhome.fr
MINIO_CONSOLE_HOST=minio.vizhome.fr
ACME_EMAIL=admin@vizhome.fr

# ─── Django ─────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=  # python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.vizhome.fr
DJANGO_CORS_ALLOWED_ORIGINS=https://app.vizhome.fr
FRONTEND_URL=https://app.vizhome.fr

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_DB=vizhome
POSTGRES_USER=vizhome
POSTGRES_PASSWORD=  # mot de passe fort obligatoire
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Storage (MinIO self-hosted) ────────────────────────────────────────────
USE_S3=True
MINIO_S3_ACCESS_KEY=
MINIO_S3_SECRET_KEY=
MINIO_S3_BUCKET_NAME=vizhome-media
MINIO_S3_REGION=us-east-1
MINIO_S3_ENDPOINT_URL=http://minio:9000
MINIO_S3_CUSTOM_DOMAIN=cdn.vizhome.fr
MINIO_S3_URL_PROTOCOL=https:

# ─── Provider IA — Gemini ───────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview
RENDERS_DEFAULT_PROVIDER=gemini

# ─── Stripe (live) ──────────────────────────────────────────────────────────
STRIPE_LIVE_MODE=True
STRIPE_LIVE_SECRET_KEY=sk_live_...
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_...
STRIPE_TEST_SECRET_KEY=
STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── OAuth ──────────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ─── Email SMTP ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@vizhome.fr

# ─── Sentry (optionnel) ─────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
