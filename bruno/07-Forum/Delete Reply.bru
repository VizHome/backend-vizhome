delete {
  url: {{baseUrl}}{{apiPrefix}}/forum/replies/{{replyId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("returns 204 or 403", function() {
    expect([204, 403]).to.include(res.getStatus());
  });
}

