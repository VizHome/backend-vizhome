# ─── Django ──────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-generate-with-django-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=vizhome
POSTGRES_USER=vizhome
POSTGRES_PASSWORD=vizhome_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis (Celery) ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── OAuth providers ─────────────────────────────────────────────────────────
# Google Cloud Console → OAuth 2.0 Client ID (Web application)
# Authorized JavaScript origins : http://localhost:3000
# Authorized redirect URIs       : http://localhost:3000/auth/oauth/google/callback
# GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxx

# GitHub Developer Settings → OAuth App
# Authorization callback URL : http://localhost:3000/auth/oauth/github/callback
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# ─── Provider IA — Gemini ────────────────────────────────────────────────────
# Récupère ta clé sur https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview
RENDERS_DEFAULT_PROVIDER=gemini

# ─── Storage S3-compatible (MinIO en dev/prod self-hosted) ───────────────────
USE_S3=True
MINIO_S3_ACCESS_KEY=vizhome
MINIO_S3_SECRET_KEY=vizhome_minio_dev_password
MINIO_S3_BUCKET_NAME=vizhome-media
MINIO_S3_REGION=us-east-1
# Endpoint interne — utilisé par Django pour parler à MinIO via le réseau Docker
MINIO_S3_ENDPOINT_URL=http://minio:9000
# Domaine public — utilisé pour construire les URLs renvoyées au frontend.
# Pour MinIO path-style, on inclut le bucket dans le path.
# Dev : localhost:9000/<bucket>  |  Prod : cdn.vizhome.fr (reverse proxy → bucket racine)
MINIO_S3_CUSTOM_DOMAIN=localhost:9000/vizhome-media
MINIO_S3_URL_PROTOCOL=http:

# ─── Stripe / dj-stripe ──────────────────────────────────────────────────────
STRIPE_LIVE_MODE=False
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_LIVE_SECRET_KEY=
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_...
STRIPE_LIVE_PUBLISHABLE_KEY=
# Récupère le webhook secret après `stripe listen --forward-to localhost:8000/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email SMTP ──────────────────────────────────────────────────────────────
# En dev : par défaut MailPit (service Docker, UI sur http://localhost:8025).
# Aucun setup nécessaire — les emails de reset password, etc. apparaissent
# automatiquement dans la web UI de MailPit.
#
# Pour les voir dans les logs Docker à la place :
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# En prod : configure ton provider SMTP (SendGrid, Mailgun, Postmark, AWS SES…)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=no-reply@vizhome.fr
