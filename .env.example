# ─── Django ──────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-generate-with-django-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=vizhome
POSTGRES_USER=vizhome
POSTGRES_PASSWORD=vizhome_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis (Celery) ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Provider IA — Gemini (étape 3) ──────────────────────────────────────────
# GEMINI_API_KEY=your-gemini-api-key
# RENDERS_DEFAULT_PROVIDER=gemini

# ─── AWS S3 (étape 4) ────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=eu-west-3

# ─── Stripe (étape 5) ────────────────────────────────────────────────────────
# STRIPE_TEST_SECRET_KEY=sk_test_...
# STRIPE_LIVE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=whsec_...

