# ─── Django ──────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-generate-with-django-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=vizhome
POSTGRES_USER=vizhome
POSTGRES_PASSWORD=vizhome_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis (Celery) ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── OAuth providers ─────────────────────────────────────────────────────────
# Google Cloud Console → OAuth 2.0 Client ID (Web application)
# Authorized JavaScript origins : http://localhost:3000
# Authorized redirect URIs       : http://localhost:3000/auth/oauth/google/callback
# GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxx

# GitHub Developer Settings → OAuth App
# Authorization callback URL : http://localhost:3000/auth/oauth/github/callback
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# ─── Provider IA — Gemini ────────────────────────────────────────────────────
# Deux backends possibles (SDK google-genai) :
#
# 1. Google AI Studio (défaut) : clé API créée sur
#    https://aistudio.google.com/apikey. La clé doit autoriser l'API
#    "Generative Language API" (erreur 403 API_KEY_SERVICE_BLOCKED sinon :
#    vérifier les restrictions de la clé dans console.cloud.google.com
#    > APIs & Services > Credentials).
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
RENDERS_DEFAULT_PROVIDER=gemini
#
# 2. Vertex AI (optionnel) : si ta clé / ton projet GCP passe par Vertex.
#    Mettre GEMINI_USE_VERTEXAI=1. Deux auth EXCLUSIVES (pas les deux) :
#    a) express mode : GEMINI_API_KEY seule (clé liée à un service account,
#       format "AQ."). Laisser GOOGLE_CLOUD_PROJECT vide.
#    b) ADC : GEMINI_API_KEY vide + GOOGLE_CLOUD_PROJECT + service account
#       via GOOGLE_APPLICATION_CREDENTIALS (JSON monté dans le container).
# GEMINI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=global

# ─── Storage S3-compatible (MinIO en dev/prod self-hosted) ───────────────────
USE_S3=True
MINIO_S3_ACCESS_KEY=vizhome
MINIO_S3_SECRET_KEY=vizhome_minio_dev_password
MINIO_S3_BUCKET_NAME=vizhome-media
MINIO_S3_REGION=us-east-1
# Endpoint interne — utilisé par Django pour parler à MinIO via le réseau Docker
MINIO_S3_ENDPOINT_URL=http://minio:9000
# Domaine public — utilisé pour construire les URLs renvoyées au frontend.
# Pour MinIO path-style, on inclut le bucket dans le path.
# Dev : localhost:9000/<bucket>  |  Prod : cdn.vizhome.fr (reverse proxy → bucket racine)
MINIO_S3_CUSTOM_DOMAIN=localhost:9000/vizhome-media
MINIO_S3_URL_PROTOCOL=http:

# ─── Stripe / dj-stripe ──────────────────────────────────────────────────────
STRIPE_LIVE_MODE=False
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_LIVE_SECRET_KEY=
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_...
STRIPE_LIVE_PUBLISHABLE_KEY=
# Récupère le webhook secret après `stripe listen --forward-to localhost:8000/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_...

# UUID de l'endpoint webhook dj-stripe (table djstripe_webhookendpoint,
# affiche par 'manage.py setup_webhook_endpoint'). Utilise par le service
# stripe-cli du docker-compose pour forwarder automatiquement les webhooks
# en dev (plus besoin de lancer 'stripe listen' a la main).
DJSTRIPE_WEBHOOK_UUID=

# ─── Email SMTP ──────────────────────────────────────────────────────────────
# En dev : par défaut MailPit (service Docker, UI sur http://localhost:8025).
# Aucun setup nécessaire — les emails de reset password, etc. apparaissent
# automatiquement dans la web UI de MailPit.
#
# Pour les voir dans les logs Docker à la place :
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# En prod : configure ton provider SMTP (SendGrid, Mailgun, Postmark, AWS SES…)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=no-reply@vizhome.fr

# Destinataire du formulaire de contact public (défaut contact@vizhome.fr)
# CONTACT_RECIPIENT_EMAIL=contact@vizhome.fr

# ─── PROD : sécurité Django supplémentaire ───────────────────────────────────
# CSRF trusted origins — surchargeable. Défaut prod : api.vizhome.fr +
# vizhome.fr + www.vizhome.fr. Ajoute ici les autres origines autorisées
# (ex: domaine app mobile, dashboard staging…).
# DJANGO_CSRF_TRUSTED_ORIGINS=https://staging.vizhome.fr,https://app.vizhome.fr

# ─── PROD : Traefik + DNS hostnames ──────────────────────────────────────────
# À renseigner uniquement pour docker-compose.prod.yml.
# Tous ces hosts doivent avoir un DNS A record pointant vers le serveur.

# Email envoyé à Let's Encrypt pour les notifications d'expiration
# ACME_EMAIL=ops@vizhome.fr

# Hostnames publics — chacun routé par Traefik vers son service
# FRONTEND_HOST=vizhome.fr
# API_HOST=api.vizhome.fr
# MINIO_PUBLIC_HOST=cdn.vizhome.fr
# MINIO_CONSOLE_HOST=minio.vizhome.fr
# TRAEFIK_DASHBOARD_HOST=traefik.vizhome.fr

# Basic Auth pour le dashboard Traefik
# Générer avec : htpasswd -nbB admin "mot-de-passe-fort"
# TRAEFIK_DASHBOARD_AUTH=admin:$2y$05$...

# Images Docker à puller (par défaut latest GHCR)
# VIZHOME_BACKEND_IMAGE=ghcr.io/vizhome/vizhome-backend:1.0.0
# VIZHOME_FRONTEND_IMAGE=ghcr.io/vizhome/vizhome-frontend:1.0.0

# ─── Bootstrap (entrypoint Docker) ───────────────────────────────────────────
# BOOTSTRAP_SKIP=0           # 1 = skip totalement (workers Celery)
# BOOTSTRAP_STRIPE_SKIP=0    # 1 = skip uniquement setup Stripe
# BOOTSTRAP_WAIT_LOCK_SECONDS=60

# ─── OpenTelemetry tracing (laisse vide pour désactiver) ─────────────────────
# Endpoint OTLP gRPC, ex : http://otel-collector:4317 (Tempo/Jaeger local)
# ou https://api.honeycomb.io:443 (Honeycomb).
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=vizhome-backend
# OTEL_ENVIRONMENT=production
# Headers OTLP si requis par le backend de tracing
# (Honeycomb : x-honeycomb-team=YOUR_KEY, Grafana Cloud : Authorization=Basic ...)
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_KEY
